FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(h|e).*"
    {
        solver          PBiCGStab;
        preconditioner  DIC; // KORREKTUR: DIC statt DILU für symmetrische Festkörpermatrizen
        tolerance       1e-08;
        relTol          0.01;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
}

relaxationFactors
{
    equations
    {
        h               0.5;
        e               0.5;
        "h.*"           0.5;
        "e.*"           0.5;
    }
}

